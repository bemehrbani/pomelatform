;;
;; Type: Bounty
;; TLB: _ owner:address oracle:address createdAt:uint32 is_complete:bool = Bounty
;;

builder $Bounty$_store(builder build_0, (slice, slice, int, int) v) inline {
    var (v'owner, v'oracle, v'createdAt, v'is_complete) = v;
    build_0 = build_0.store_slice(v'owner);
    build_0 = build_0.store_slice(v'oracle);
    build_0 = build_0.store_uint(v'createdAt, 32);
    build_0 = build_0.store_int(v'is_complete, 1);
    return build_0;
}

(slice, ((slice, slice, int, int))) $Bounty$_load(slice sc_0) inline {
    var v'owner = sc_0~load_msg_addr();
    var v'oracle = sc_0~load_msg_addr();
    var v'createdAt = sc_0~load_uint(32);
    var v'is_complete = sc_0~load_int(1);
    return (sc_0, (v'owner, v'oracle, v'createdAt, v'is_complete));
}

(slice, ((slice, slice))) $Bounty$init$_load(slice sc_0) inline {
    var v'owner = sc_0~load_msg_addr();
    var v'oracle = sc_0~load_msg_addr();
    return (sc_0, (v'owner, v'oracle));
}

(slice, slice, int, int) $Bounty$_contract_load() impure inline {
    slice $sc = get_data().begin_parse();
    int $loaded = $sc~load_int(1);
    if ($loaded) {
        return $sc~$Bounty$_load();
    }
    else {
        (slice $owner, slice $oracle) = $sc~$Bounty$init$_load();
        $sc.end_parse();
        return $Bounty$_contract_init($owner, $oracle);
    }
}

() $Bounty$_contract_store((slice, slice, int, int) v) impure inline {
    builder b = begin_cell();
    b = b.store_int(true, 1);
    b = $Bounty$_store(b, v);
    set_data(b.end_cell());
}

;;
;; Contract Bounty functions
;;

(slice, slice, int, int) $Bounty$_contract_init(slice $owner, slice $oracle) impure inline {
    var (($self'owner, $self'oracle, $self'createdAt, $self'is_complete)) = (null(), null(), null(), null());
    $self'owner = $owner;
    $self'oracle = $oracle;
    $self'createdAt = $global_now();
    $self'is_complete = false;
    return ($self'owner, $self'oracle, $self'createdAt, $self'is_complete);
}

((slice, slice, int, int), int) $Bounty$_fun_balance((slice, slice, int, int) $self) impure inline_ref {
    var (($self'owner, $self'oracle, $self'createdAt, $self'is_complete)) = $self;
    var $fresh$ret_0 = $global_myBalance();
    return (($self'owner, $self'oracle, $self'createdAt, $self'is_complete), $fresh$ret_0);
}

((slice, slice, int, int), slice) $Bounty$_fun_owner((slice, slice, int, int) $self) impure inline_ref {
    var (($self'owner, $self'oracle, $self'createdAt, $self'is_complete)) = $self;
    var $fresh$ret_1 = $self'owner;
    return (($self'owner, $self'oracle, $self'createdAt, $self'is_complete), $fresh$ret_1);
}

;;
;; Get methods of a Contract Bounty
;;

_ %balance() method_id(104128) {
    var self = $Bounty$_contract_load();
    var res = self~$Bounty$_fun_balance();
    return res;
}

_ %owner() method_id(83229) {
    var self = $Bounty$_contract_load();
    var res = self~$Bounty$_fun_owner();
    return res;
}

;;
;; Routing of a Contract Bounty
;;

;; message opcode reader utility: only binary receivers
;; Returns 32 bit message opcode, otherwise throws the "Invalid incoming message" exit code
(slice, int) ~load_opcode_internal(slice s) asm( -> 1 0) "32 LDUQ 130 THROWIFNOT";

() recv_internal(int msg_value, cell in_msg_cell, slice in_msg) impure {
    
    ;; Context
    var cs = in_msg_cell.begin_parse();
    cs~skip_bits(2);
    var msg_bounceable = cs~load_int(1);
    var msg_bounced = cs~load_int(1);
    slice msg_sender_addr = cs~load_msg_addr();
    __tact_context = (msg_bounceable, msg_sender_addr, msg_value, cs);
    __tact_context_sender = msg_sender_addr;
    
    ;; Load contract data
    var ($self'owner, $self'oracle, $self'createdAt, $self'is_complete) = $Bounty$_contract_load();
    
    ;; Handle bounced messages
    if (msg_bounced) { return (); }
    int op = 0;
    int in_msg_length = slice_bits(in_msg);
    if (in_msg_length >= 32) {
        op = in_msg~load_uint(32);
    }
    ;; Receive Payout message
    if (op == 3422234645) {
        var $msg'amount = in_msg~load_varuint16();
        var $msg'recipient = in_msg~load_msg_addr();
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        throw_unless(11551, ( equal_slices_bits($ctx'sender, $self'oracle) ));
        throw_unless(30194, ($self'is_complete == false));
        throw_unless(54615, ($global_myBalance() >= $msg'amount));
        $self'is_complete = true;
        $global_send($SendParameters$_constructor_to_value_mode_body($msg'recipient, $msg'amount, 3, __gen_cell_cell_c0566e0b757891a9f4a988e677cce0459403a66dbfa9250af5931b055573cd52()));
        $Bounty$_contract_store(($self'owner, $self'oracle, $self'createdAt, $self'is_complete));
        return ();
    }
    
    ;; Receive Refund message
    if (op == 4125046507) {
        var $msg'query_id = in_msg~load_uint(64);
        var ($ctx'bounceable, $ctx'sender, $ctx'value, $ctx'raw) = __tact_context_get();
        throw_unless(47362, ( equal_slices_bits($ctx'sender, $self'owner) ));
        throw_unless(40083, ($global_now() > ($self'createdAt + 604800)));
        $global_send($SendParameters$_constructor_to_value_mode_body($self'owner, 0, 128, __gen_cell_cell_73cc63e7c356e26074f0ebda69a9c9185fb7800f91f62bc094ce49e050523850()));
        $Bounty$_contract_store(($self'owner, $self'oracle, $self'createdAt, $self'is_complete));
        return ();
    }
    
    ;; Receive Deploy message
    if (op == 0x946a98b6) {
        var $deploy'queryId = in_msg~load_uint(64);
        ($self'owner, $self'oracle, $self'createdAt, $self'is_complete)~$Bounty$_fun_notify($DeployOk$_store_cell($DeployOk$_constructor_queryId($deploy'queryId), begin_cell()));
        $Bounty$_contract_store(($self'owner, $self'oracle, $self'createdAt, $self'is_complete));
        return ();
    }
    
    ;; Receive empty message
    if ((op == 0) & (in_msg_length <= 32)) {
        $Bounty$_contract_store(($self'owner, $self'oracle, $self'createdAt, $self'is_complete));
        return ();
    }
    ;; Throw if not handled
    throw(130);
}


() __tact_selector_hack_asm() impure asm """
@atend @ 1 {
        execute current@ context@ current!
        {
            // The core idea of this function is to save gas by avoiding unnecessary dict jump, when recv_internal/recv_external is called
            // We want to extract recv_internal/recv_external from the dict and select needed function
            // not by jumping to the needed function by it's index, but by using usual IF statements.

            }END> b> // Close previous builder, now we have a cell of previous code on top of the stack

            <{ // Start of the new code builder
                SETCP0
                // Swap the new code builder with the previous code, now we have previous code on top of the stack
                swap
                // Transform cell to slice and load first ref from the previous code, now we have the dict on top of the stack
                <s ref@

                // Extract the recv_internal from the dict
                dup 0 swap @procdictkeylen idict@ { "internal shortcut error" abort } ifnot
                swap

                // Delete the recv_internal from the dict
                0 swap @procdictkeylen idict- drop
                // Delete the recv_external from the dict (it's okay if it's not there)
                -1 swap @procdictkeylen idict- drop
                // Delete the __tact_selector_hack from the dict
                65535 swap @procdictkeylen idict- drop

                // Bring the code builder from the bottom of the stack
                // because if recv_external extraction is optional, and the number of elements on the stack is not fixed
                depth 1- roll
                // Swap with the dict from which we extracted recv_internal and (maybe) recv_external
                swap

                // Check if the dict is empty
                dup null?
                // Store a copy of this flag in the bottom of the stack
                dup depth 1- -roll
                {
                    // If the dict is empty, just drop it (it will be null if it's empty)
                    drop
                }
                {
                    // If the dict is not empty, prepare continuation to be stored in c3
                    <{
                        // Save this dict as first ref in this continuation, it will be pushed in runtime by DICTPUSHCONST
                        swap @procdictkeylen DICTPUSHCONST
                        // Jump to the needed function by it's index
                        DICTIGETJMPZ
                        // If such key is not found, throw 11 along with the key as an argument
                        11 THROWARG
                    }> PUSHCONT
                    // Store the continuation in c3
                    c3 POP
                } cond

                // Function id is on top of the (runtime) stack
                DUP IFNOTJMP:<{
                    // place recv_internal here
                    DROP swap @addop
                }>

                // Bring back the flag, indicating if the dict is empty or not from the bottom of the stack
                depth 1- roll
                {
                    // If the dict is empty, throw 11
                    11 THROWARG
                }
                {
                    // If the dict is not empty, jump to continuation from c3
                    c3 PUSH JMPX
                } cond
            }> b>
        } : }END>c
        current@ context! current!
    } does @atend !
""";

() __tact_selector_hack() method_id(65535) {
    return __tact_selector_hack_asm();
}